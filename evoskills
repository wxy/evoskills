#!/bin/bash

set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
CLI_VERSION="3.1.0"

# Project config file (in current directory)
PROJECT_CONFIG_FILE=".evoskills-config.json"

AGENTS_DIR=".agent"
SKILLS_DIR="$AGENTS_DIR/skills"

# Default skill repository
DEFAULT_SKILLS_REPO="https://github.com/wxy/evoskills"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

CORE_SKILLS=(
  "_evolution-core"
  "_skills-manager"
)

REQUIRED_SKILLS=(
  "_instruction-guard"
  "_context-ack"
  "_file-output-guard"
  "_execution-precheck"
)

OPTIONAL_SKILLS=(
  "_git-commit"
  "_pr-creator"
  "_release-process"
  "_code-health-check"
  "_typescript-type-safety"
  "_change-summary"
  "_traceability-check"
  "_session-safety"
)

print_success() { echo -e "${GREEN}✅ $*${NC}"; }
print_info() { echo -e "${BLUE}ℹ️  $*${NC}"; }
print_warn() { echo -e "${YELLOW}⚠️  $*${NC}"; }
print_error() { echo -e "${RED}❌ $*${NC}"; }

show_help() {
  cat << 'EOF'
evoskills - Evolution Skills CLI

Usage:
  evoskills <command> [options]

Commands:
  init [OPTIONS]              Initialize project skills
    --core-only               Install core skills only (2 skills)
    --required-only           Install core + required system skills
    --skills <list>           Install selected skills (comma-separated)
    --all                     Install all skills (default)
    --repo <url>              Use custom skill repository (saved to .evoskills-config.json)

  list [--installed]          List available or installed skills
  install <skill>             Install a skill from configured repository
  add <skill>                 Alias of install
  remove <skill>              Remove a skill
  update [OPTIONS]            Update CLI and refresh skills/constitution
    --repo <url>              Switch to a different skill repository
    [skill]                   Update specific skill only (omit to update all)
  contribute <skill>          Start contribution flow for a skill
  --version, -v               Print CLI version
  --help, -h                  Print this help

Default repository: https://github.com/wxy/evoskills

Notes:
  - Skills are installed to .agent/skills/
  - Repository URL is auto-saved in .evoskills-config.json when using --repo
  - 'update' without args refreshes CLI (via npm) and all skills from saved repo
  - AGENTS.md is auto-generated for openskills compatibility
  - Skill tiers: Core (2), Required System (4), Optional (8)
EOF
}

ensure_layout() {
  mkdir -p "$SKILLS_DIR"
  mkdir -p ".github"
}

github_raw_url() {
  local repo_url="$1"
  local path="$2"
  # Convert https://github.com/user/repo to https://raw.githubusercontent.com/user/repo/main/path
  local raw_repo
  raw_repo=$(echo "$repo_url" | sed 's|https://github.com/|https://raw.githubusercontent.com/|' | sed 's|\.git$||')
  echo "$raw_repo/main/$path"
}

get_config_value() {
  local key="$1"

  # Return default if no config file exists
  if [ ! -f "$PROJECT_CONFIG_FILE" ]; then
    case "$key" in
      skillsRepo) echo "$DEFAULT_SKILLS_REPO" ;;
      *) echo "" ;;
    esac
    return
  fi

  # Try to read from config file
  if command -v jq &> /dev/null; then
    jq -r ".\"$key\" // empty" "$PROJECT_CONFIG_FILE" 2>/dev/null || echo ""
  else
    grep "\"$key\"" "$PROJECT_CONFIG_FILE" | sed 's/.*": "\(.*\)".*/\1/' || echo ""
  fi
}

set_config_value() {
  local key="$1"
  local value="$2"

  # Create empty config if it doesn't exist
  if [ ! -f "$PROJECT_CONFIG_FILE" ]; then
    echo "{}" > "$PROJECT_CONFIG_FILE"
  fi

  # Update config file
  if command -v jq &> /dev/null; then
    jq ".\"$key\" = \"$value\"" "$PROJECT_CONFIG_FILE" > "${PROJECT_CONFIG_FILE}.tmp" && mv "${PROJECT_CONFIG_FILE}.tmp" "$PROJECT_CONFIG_FILE"
  else
    # Fallback: simple sed replacement or append
    if grep -q "\"$key\"" "$PROJECT_CONFIG_FILE"; then
      sed -i '' "s/\"$key\": \"[^\"]*\"/\"$key\": \"$value\"/" "$PROJECT_CONFIG_FILE"
    else
      sed -i '' '$ s/}/,"'$key'": "'$value'"}/' "$PROJECT_CONFIG_FILE"
    fi
  fi

  print_success "Config saved: $key = $value"
}

# Download file from GitHub with strict error handling
# Usage: github_download <skills_repo> <file_path> <output_file> <allow_stub>
# allow_stub: if 'true', fail fast on error; if 'false', skip on error
github_download() {
  local skills_repo="$1"
  local file_path="$2"
  local output_file="$3"
  local allow_stub="$4"
  local raw_url
  local temp_file
  
  raw_url=$(github_raw_url "$skills_repo" "$file_path")
  temp_file=$(mktemp)
  
  if curl -sf "$raw_url" > "$temp_file" 2>/dev/null; then
    mv "$temp_file" "$output_file"
    print_success "Downloaded $file_path"
    return 0
  else
    rm -f "$temp_file"
    if [ "$allow_stub" = "true" ]; then
      print_error "Failed to download $file_path from $skills_repo"
      print_error "Cannot initialize project without critical files"
      return 1
    else
      print_warn "Could not download $file_path; skipping update"
      return 2
    fi
  fi
}

create_constitution_if_missing() {
  if [ ! -f ".github/AI_CONSTITUTION.md" ]; then
    local skills_repo
    skills_repo=$(get_config_value "skillsRepo")
    github_download "$skills_repo" ".github/AI_CONSTITUTION.md" ".github/AI_CONSTITUTION.md" "true"
    if [ $? -ne 0 ]; then
      print_error "AI_CONSTITUTION.md is required for initialization"
      exit 1
    fi
  fi
}

create_initialization_if_missing() {
  if [ ! -f ".github/AI_INITIALIZATION.md" ]; then
    local skills_repo
    skills_repo=$(get_config_value "skillsRepo")
    github_download "$skills_repo" ".github/AI_INITIALIZATION.md" ".github/AI_INITIALIZATION.md" "true"
    if [ $? -ne 0 ]; then
      print_error "AI_INITIALIZATION.md is required for initialization"
      exit 1
    fi
  fi
}

update_constitution() {
  local skills_repo
  skills_repo=$(get_config_value "skillsRepo")
  local raw_url
  raw_url=$(github_raw_url "$skills_repo" ".github/AI_CONSTITUTION.md")
  
  if curl -sf "$raw_url" > ".github/AI_CONSTITUTION.md" 2>/dev/null; then
    print_success "Updated .github/AI_CONSTITUTION.md"
    return 0
  else
    print_warn "Could not update .github/AI_CONSTITUTION.md from remote"
    return 1
  fi
}

update_initialization() {
  local skills_repo
  skills_repo=$(get_config_value "skillsRepo")
  local raw_url
  raw_url=$(github_raw_url "$skills_repo" ".github/AI_INITIALIZATION.md")
  
  if curl -sf "$raw_url" > ".github/AI_INITIALIZATION.md" 2>/dev/null; then
    print_success "Updated .github/AI_INITIALIZATION.md"
    return 0
  else
    print_warn "Could not update .github/AI_INITIALIZATION.md from remote"
    return 1
  fi
}

create_copilot_instructions_if_missing() {
  if [ ! -f ".github/copilot-instructions.md" ]; then
    cat > ".github/copilot-instructions.md" << 'EOF'
---
applyTo: "**"
---

## Core Documents (Required)

Please read and follow the AI evolution principle:
- `.github/AI_CONSTITUTION.md` - Core evolution mechanism (always active, cannot be disabled)

## Mandatory Initialization Protocol

For enforced execution sequence:
- `.github/AI_INITIALIZATION.md` - 4-skill initialization protocol (mandatory before each response)

## Skills Registry

For available skills and how they work:
- `AGENTS.md` - Skill registry with core, required system, and optional skills

---

**Note**: The AI will continuously evolve by learning from errors, user feedback, and complex workflows. This is built into the core system and cannot be disabled.
EOF
    print_success "Created .github/copilot-instructions.md"
  else
    # Check if copilot-instructions already has evoskills entries
    if ! grep -q "AI_CONSTITUTION.md" ".github/copilot-instructions.md" && \
       ! grep -q "AI_INITIALIZATION.md" ".github/copilot-instructions.md" && \
       ! grep -q "AGENTS.md" ".github/copilot-instructions.md"; then
      # Only add if none of the evoskills references exist
      echo "" >> ".github/copilot-instructions.md"
      echo "## Embedded AI Skills Framework" >> ".github/copilot-instructions.md"
      echo "" >> ".github/copilot-instructions.md"
      echo "This project uses evoskills for AI-assisted development:" >> ".github/copilot-instructions.md"
      echo "- `.github/AI_CONSTITUTION.md` - Core evolution mechanism (always active)" >> ".github/copilot-instructions.md"
      echo "- `.github/AI_INITIALIZATION.md` - Mandatory 4-skill initialization protocol" >> ".github/copilot-instructions.md"
      echo "- `AGENTS.md` - Skill registry (core, required system, and optional skills)" >> ".github/copilot-instructions.md"
      print_success "Updated .github/copilot-instructions.md with evoskills framework"
    fi
  fi
}

write_agents_registry() {
  local is_installed
  is_installed() {
    [ -d "$SKILLS_DIR/$1" ]
  }

  local skill_description
  skill_description() {
    case "$1" in
      _evolution-core) echo "Identify improvement opportunities and patterns in code and processes. Proposes enhancements based on architectural patterns and best practices. Core mechanism of continuous system evolution." ;;
      _skills-manager) echo "Core skill manager for evoskills. Handles skill lifecycle (init, install, remove, update) and skill contributions. Core mechanism managing the skill ecosystem." ;;
      _instruction-guard) echo "Read and apply directives before processing each request. Enforces instruction hierarchy and prevents instruction conflicts." ;;
      _context-ack) echo "Format responses with clear headers, footers, and reference lists. Ensures proper context acknowledgment and response structure." ;;
      _file-output-guard) echo "Validate and safeguard all file creation operations. Prevents unsafe file creation patterns and unauthorized modifications." ;;
      _execution-precheck) echo "Validate dependencies and runtime requirements before executing commands. Ensures all prerequisites are met before task execution." ;;
      _git-commit) echo "Implement conventional commits workflow. Ensures proper commit message formatting and semantic versioning compliance." ;;
      _pr-creator) echo "Automate PR generation with version detection and release notes. Streamlines contributions and version management." ;;
      _release-process) echo "Execute complete release workflow. Coordinates versioning, tagging, and publication of releases." ;;
      _code-health-check) echo "Perform quality checks before commit. Validates code standards, security, and architectural consistency." ;;
      _typescript-type-safety) echo "Enforce TypeScript type safety guidelines. Ensures proper typing and prevents type-related runtime errors." ;;
      _change-summary) echo "Summarize completed work sessions. Provides concise summaries of changes and progress made." ;;
      _traceability-check) echo "Ensure all decisions are properly documented. Validates decision traceability and documentation completeness." ;;
      _session-safety) echo "Prevent state violations and session inconsistencies. Maintains context integrity and prevents conflicting actions." ;;
      *) echo "Skill: $1" ;;
    esac
  }

  local add_skill_entry
  add_skill_entry() {
    local skill="$1"
    if is_installed "$skill"; then
      cat >> "$temp_content" << EOF
<skill>
<name>$skill</name>
<description>$(skill_description "$skill")</description>
<location>project</location>
</skill>

EOF
    fi
  }

  # Generate our skills section in a temp file
  local temp_content=".evoskills-section.tmp"
  cat > "$temp_content" << 'MARKER_EOF'
<!-- EVOSKILLS_START -->
<skills_system priority="1">

## Available Skills (evoskills)

<!--
SKILLS_TABLE_START -->
<usage>
When users ask you to perform tasks, check if any of the
available skills below can help complete the task more effectively. Skills provide
specialized capabilities and domain knowledge.

How to use skills:
- Invoke: Bash("npx openskills read <skill-name>")
- The skill content will load with detailed instructions on how to complete the task
- Base directory provided in output for resolving bundled resources (references/, scripts/, assets/)

Usage notes:
- Only use skills listed in <available_skills> below
- Do not invoke a skill that is already loaded in your context
- Each skill invocation is stateless
</usage>

<available_skills>

<!-- Tier 1: Core Skills (2) - Evolution Infrastructure -->

MARKER_EOF

  for skill in "${CORE_SKILLS[@]}"; do
    add_skill_entry "$skill"
  done

  cat >> "$temp_content" << 'MARKER_EOF'

<!-- Tier 2: System Skills (4) - Required for Safe Operation -->

MARKER_EOF

  for skill in "${REQUIRED_SKILLS[@]}"; do
    add_skill_entry "$skill"
  done

  cat >> "$temp_content" << 'MARKER_EOF'

<!-- Tier 3: Optional Skills (8) - User-Selectable Enhancements -->

MARKER_EOF

  for skill in "${OPTIONAL_SKILLS[@]}"; do
    add_skill_entry "$skill"
  done

  cat >> "$temp_content" << 'MARKER_EOF'

</available_skills>
<!--
SKILLS_TABLE_END -->

</skills_system>
<!-- EVOSKILLS_END -->
MARKER_EOF

  # Update or create AGENTS.md
  if [ ! -f "AGENTS.md" ]; then
    # Create new file
    cat > "AGENTS.md" << 'EOF'
# AGENTS

EOF
    cat "$temp_content" >> "AGENTS.md"
    print_success "Created AGENTS.md"
  else
    # Check if our markers exist
    if grep -q "<!-- EVOSKILLS_START -->" "AGENTS.md" && grep -q "<!-- EVOSKILLS_END -->" "AGENTS.md"; then
      # Replace content between markers using sed
      local agents_tmp="AGENTS.md.tmp"
      
      # Extract content before EVOSKILLS_START
      sed -n '1,/<!-- EVOSKILLS_START -->/p' "AGENTS.md" | sed '$d' > "$agents_tmp"
      
      # Add our new content
      cat "$temp_content" >> "$agents_tmp"
      
      # Extract content after EVOSKILLS_END
      sed -n '/<!-- EVOSKILLS_END -->/,$p' "AGENTS.md" | tail -n +2 >> "$agents_tmp"
      
      mv "$agents_tmp" "AGENTS.md"
      print_success "Updated evoskills section in AGENTS.md"
    else
      # Append our section to existing file
      echo "" >> "AGENTS.md"
      cat "$temp_content" >> "AGENTS.md"
      print_success "Appended evoskills section to AGENTS.md"
    fi
  fi
  
  # Cleanup
  rm -f "$temp_content"
}

install_skill_github() {
  local skill="$1"
  local skills_repo
  skills_repo=$(get_config_value "skillsRepo")

  if [ -d "$SKILLS_DIR/$skill" ]; then
    print_warn "Skill already installed: $skill"
    return 0
  fi

  mkdir -p "$SKILLS_DIR/$skill"

  # Try to download SKILL.md and references from GitHub
  local raw_url
  raw_url=$(github_raw_url "$skills_repo" ".agent/skills/$skill/SKILL.md")
  if curl -sf "$raw_url" > "$SKILLS_DIR/$skill/SKILL.md" 2>/dev/null; then
    print_success "Installed skill: $skill"

    # Try to download references/ if present
    local ref_url
    ref_url=$(github_raw_url "$skills_repo" ".agent/skills/$skill/references/")
    if curl -sf "$ref_url" &>/dev/null; then
      print_info "Downloading skill references..."
      mkdir -p "$SKILLS_DIR/$skill/references"
      # Download common reference files
      for ref_file in "*.md"; do
        local ref_file_url
        ref_file_url=$(github_raw_url "$skills_repo" ".agent/skills/$skill/references/$ref_file")
        curl -sf "$ref_file_url" > "$SKILLS_DIR/$skill/references/$ref_file" 2>/dev/null || true
      done
    fi

    # Try to download scripts/ if present
    local script_url
    script_url=$(github_raw_url "$skills_repo" ".agent/skills/$skill/scripts/")
    if curl -sf "$script_url" &>/dev/null; then
      print_info "Downloading skill scripts..."
      mkdir -p "$SKILLS_DIR/$skill/scripts"
      for script_file in "*.sh"; do
        local script_file_url
        script_file_url=$(github_raw_url "$skills_repo" ".agent/skills/$skill/scripts/$script_file")
        curl -sf "$script_file_url" > "$SKILLS_DIR/$skill/scripts/$script_file" 2>/dev/null || true
      done
    fi
  else
    print_error "Failed to download skill: $skill from $skills_repo"
    rm -rf "$SKILLS_DIR/$skill"
    return 1
  fi
}

cmd_init() {
  local core_only=false
  local required_only=false
  local skills=""
  local install_all=true
  local custom_repo=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --core-only)
        core_only=true
        install_all=false
        shift
        ;;
      --required-only)
        required_only=true
        install_all=false
        shift
        ;;
      --skills)
        skills="$2"
        install_all=false
        shift 2
        ;;
      --all)
        install_all=true
        shift
        ;;
      --repo)
        custom_repo="$2"
        set_config_value "skillsRepo" "$custom_repo"
        shift 2
        ;;
      *)
        print_error "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  ensure_layout

  # Initialize config with default repository if not already set
  local skills_repo
  if [ -z "$custom_repo" ]; then
    skills_repo="$DEFAULT_SKILLS_REPO"
  else
    skills_repo="$custom_repo"
  fi

  cat > "$PROJECT_CONFIG_FILE" << EOF
{
  "version": "3.1.0",
  "installedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "skillsDir": ".agent/skills",
  "openskillsCompatible": true,
  "skillsRepo": "$skills_repo"
}
EOF

  create_constitution_if_missing
  create_initialization_if_missing
  create_copilot_instructions_if_missing

  print_success "Core framework files downloaded and verified"
  print_info "Installing core skills..."
  for skill in "${CORE_SKILLS[@]}"; do
    install_skill_github "$skill"
  done

  if [ "$core_only" = false ]; then
    print_info "Installing required system skills..."
    for skill in "${REQUIRED_SKILLS[@]}"; do
      install_skill_github "$skill"
    done
  fi

  if [ "$core_only" = false ] && [ "$required_only" = false ]; then
    if [ -n "$skills" ]; then
      print_info "Installing selected skills..."
      for skill in ${skills//,/ }; do
        install_skill_github "$skill"
      done
    elif [ "$install_all" = true ]; then
      print_info "Installing all optional skills..."
      for skill in "${OPTIONAL_SKILLS[@]}"; do
        install_skill_github "$skill"
      done
    fi
  fi

  write_agents_registry
  print_success "Initialization complete (.agent/skills + AGENTS.md + AI_CONSTITUTION.md)"
}

cmd_list() {
  local show_installed=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --installed) show_installed=true ;;
    esac
    shift
  done

  if [ "$show_installed" = true ]; then
    if [ -d "$SKILLS_DIR" ]; then
      find "$SKILLS_DIR" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
    else
      print_warn ".agent/skills not found. Run: evoskills init"
    fi
    return
  fi

  echo "Core skills:"
  for skill in "${CORE_SKILLS[@]}"; do
    echo "  - $skill"
  done

  echo "Required system skills:"
  for skill in "${REQUIRED_SKILLS[@]}"; do
    echo "  - $skill"
  done

  echo "Optional skills:"
  for skill in "${OPTIONAL_SKILLS[@]}"; do
    echo "  - $skill"
  done
}

cmd_install() {
  local skill="$1"
  [ -z "$skill" ] && { print_error "Usage: evoskills install <skill>"; exit 1; }

  ensure_layout
  install_skill_github "$skill"
  write_agents_registry
}

cmd_remove() {
  local skill="$1"
  [ -z "$skill" ] && { print_error "Usage: evoskills remove <skill>"; exit 1; }

  case "$skill" in
    _evolution-core|_skills-manager|_instruction-guard|_context-ack|_file-output-guard|_execution-precheck)
      print_error "Cannot remove core/required skill: $skill"
      exit 1
      ;;
  esac

  if [ -d "$SKILLS_DIR/$skill" ]; then
    rm -rf "$SKILLS_DIR/$skill"
    print_success "Removed skill: $skill"
    write_agents_registry
  else
    print_warn "Skill is not installed: $skill"
  fi
}

cmd_update() {
  local skill=""
  local custom_repo=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        custom_repo="$2"
        set_config_value "skillsRepo" "$custom_repo"
        shift 2
        ;;
      *)
        if [[ ! "$1" =~ ^-- ]]; then
          skill="$1"
        fi
        shift
        ;;
    esac
  done

  # Update CLI itself if no specific skill requested
  if [ -z "$skill" ]; then
    if command -v npm &> /dev/null; then
      print_info "Updating evoskills CLI..."
      npm install -g @xingyu.wang/evoskills@latest 2>/dev/null || print_warn "CLI update failed (may need sudo or already latest)"
    else
      print_warn "npm not found; skipping CLI update"
    fi
  fi

  ensure_layout
  update_constitution
  update_initialization
  create_copilot_instructions_if_missing

  if [ -n "$skill" ]; then
    print_info "Refreshing skill: $skill"
    rm -rf "$SKILLS_DIR/$skill"
    install_skill_github "$skill"
  else
    print_info "Refreshing all skills from $(get_config_value 'skillsRepo')..."
    # Refresh all installed skills
    if [ -d "$SKILLS_DIR" ]; then
      for installed_skill in "$SKILLS_DIR"/*; do
        if [ -d "$installed_skill" ]; then
          skill_name=$(basename "$installed_skill")
          print_info "Updating $skill_name..."
          rm -rf "$installed_skill"
          install_skill_github "$skill_name"
        fi
      done
    fi
  fi

  write_agents_registry
  print_success "Update complete"
}

cmd_contribute() {
  local skill="$1"
  [ -z "$skill" ] && { print_error "Usage: evoskills contribute <skill>"; exit 1; }

  if [ ! -d "$SKILLS_DIR/$skill" ]; then
    print_error "Skill not found: $skill (expected in .agent/skills/)"
    exit 1
  fi

  print_info "Contribution flow:"
  print_info "1. Fork the repository"
  print_info "2. Create a feature branch: git checkout -b feature/update-$skill"
  print_info "3. Update skill in .agent/skills/$skill/"
  print_info "4. Commit: git commit -m 'feat: update $skill'"
  print_info "5. Push and open a pull request"
}

main() {
  local command="$1"
  shift || true

  case "$command" in
    init) cmd_init "$@" ;;
    list) cmd_list "$@" ;;
    install|add) cmd_install "$@" ;;
    remove) cmd_remove "$@" ;;
    update) cmd_update "$@" ;;
    contribute) cmd_contribute "$@" ;;
    --version|-v) echo "evoskills version $CLI_VERSION" ;;
    --help|-h|help|"") show_help ;;
    *) print_error "Unknown command: $command"; show_help; exit 1 ;;
  esac
}

main "$@"
